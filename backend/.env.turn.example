# TURN Server Configuration
# Provides reliable WebRTC connections across networks and NAT using TURN protocol

# ===== TURN Provider Selection =====
# Determines which TURN server provider to use
# Options: metered | twilio | manual | (empty for STUN only)
TURN_PROVIDER=metered

# ===== Metered.ca Configuration =====
# Metered provides reliable TURN servers with a simple API key model
# Get free API key at: https://metered.ca/
# Supports both UDP and TCP with TLS
METERED_API_KEY=your_metered_api_key_here

# ===== Twilio Configuration =====
# Twilio provides TURN servers with dynamic credential generation
# Get credentials at: https://console.twilio.com/
# Requires account SID and auth token for credential generation
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ===== Manual TURN Configuration =====
# Use this if you're running your own TURN server (coturn/reTurn)
# Only used if TURN_PROVIDER=manual
TURN_HOST=turn.example.com
TURN_PORT=3478
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword

# ===== WebRTC Settings =====
# Preferred ICE Candidate type for better performance
# Options: all | srflx (don't use host candidates) | prflx
WEBRTC_ICE_CANDIDATE_POLICY=all

# ICE transport policy
# Options: all | relay (force TURN relay, higher latency but more privacy)
WEBRTC_ICE_TRANSPORT_POLICY=all
