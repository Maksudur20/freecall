# Redis Configuration for Caching and Real-time Performance
# Choose one of the following Redis providers

# ====== UPSTASH REDIS (Recommended for Vercel/Cloud) ======
# Get your URL from: https://console.upstash.com/
# Format: redis://default:PASSWORD@HOST:PORT
# Example: redis://default:AXJqd3AtWJ8uxC@us1-calm-finch-12345.upstash.io:39247
REDIS_URL=

# ====== REDIS CLOUD (Alternative) ======
# Get your URL from: https://app.redislab.com/
# REDIS_URL=redis://:PASSWORD@HOST:PORT

# ====== LOCAL REDIS (Development Only) ======
# REDIS_URL=redis://localhost:6379

# Redis Cache Configuration
REDIS_CACHE_ENABLED=true

# Cache TTLs (Time to Live in seconds)
REDIS_CACHE_USER_TTL=3600        # User cache: 1 hour
REDIS_CACHE_CHAT_TTL=1800        # Chat cache: 30 minutes
REDIS_CACHE_MESSAGE_TTL=1200     # Messages: 20 minutes
REDIS_CACHE_SESSION_TTL=86400    # Sessions: 24 hours
REDIS_CACHE_FRIENDS_TTL=7200     # Friends list: 2 hours

# Socket.io Configuration
SOCKETIO_REDIS_ADAPTER_ENABLED=true  # Enable Socket.io Redis adapter for scaling
SOCKETIO_PING_INTERVAL=25000         # Socket.io ping interval (ms)
SOCKETIO_PING_TIMEOUT=60000          # Socket.io ping timeout (ms)
