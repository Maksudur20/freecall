# Production Environment Variables for Render
# Copy these values to Render Dashboard > Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection
MONGODB_ATLAS_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/freecall

# JWT Configuration (CHANGE THESE!)
JWT_SECRET=your_very_long_secret_key_min_32_chars_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_very_long_refresh_secret_change_in_production
REFRESH_TOKEN_EXPIRE=30d

# CORS Configuration - Add all domains that will access this API
# Format: domain1.com,domain2.com,domain3.com
CORS_ORIGIN=https://freecall-nine.vercel.app,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,pdf,docx,txt

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis Configuration (for caching and Socket.io scaling)
REDIS_URL=redis://username:password@host:port

# Email Configuration
TURN_PROVIDER=metered
METERED_API_KEY=your_metered_api_key
# OR for Twilio:
# TURN_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxx
# TWILIO_AUTH_TOKEN=xxxx

# Optional: Frontend URL for email verification links
FRONTEND_URL=https://freecall-nine.vercel.app

# Optional: Sendgrid or SMTP for email
EMAIL_PROVIDER=metered
SENDGRID_API_KEY=your_sendgrid_key
