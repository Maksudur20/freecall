# Email Service Configuration

# Email Provider Selection
# Set to 'sendgrid' for SendGrid, 'smtp' for custom SMTP, or leave empty for console logging only
EMAIL_PROVIDER=sendgrid

# ===== SendGrid Configuration =====
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ===== SMTP Configuration (Alternative to SendGrid) =====
# SMTP Host (e.g., smtp.gmail.com, smtp.office365.com)
SMTP_HOST=smtp.gmail.com

# SMTP Port (usually 587 for TLS, 465 for SSL, 25 for unencrypted)
SMTP_PORT=587

# SMTP Username/Email
SMTP_USER=your-email@gmail.com

# SMTP Password or App Password
SMTP_PASSWORD=your_app_password

# Enable TLS/SSL
SMTP_SECURE=true

# From Email Address (sender email for all outgoing emails)
SMTP_FROM_EMAIL=noreply@freecall.com

# ===== Frontend Configuration =====
# Frontend URL for email verification and password reset links
# Used to generate clickable links in emails
FRONTEND_URL=http://localhost:3000

# Production Frontend URL (if different)
# FRONTEND_URL=https://freecall-i2xrlws2k-maksudur20s-projects.vercel.app

# ===== Redis Configuration for Token Storage =====
# If not set, tokens will be stored in memory (lost on server restart)
REDIS_URL=redis://localhost:6379
# or for Upstash: REDIS_URL=redis://default:password@host:port

# ===== Email Service Fallback =====
# If both SendGrid and SMTP are misconfigured, emails will log to console
# This is useful for development without actual email sending setup

# ===== Token Expiration =====
# These are set in the token service (services/token.js)
# Email verification token: 24 hours
# Password reset token: 1 hour
# You can modify these in the token service if needed

# ===== Testing Email Service =====
# To test without real email setup:
# 1. Leave EMAIL_PROVIDER empty or undefined
# 2. Check server logs for email content (printed to console)
# 3. Copy/paste links from logs for testing
